<?xml version="1.0" encoding="UTF-8"?>
<MPD xmlns="urn:mpeg:dash:schema:mpd:2011"
     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:schemaLocation="urn:mpeg:dash:schema:mpd:2011 DASH-MPD.xsd"
     type="static"
     mediaPresentationDuration="PT4M0.00S"
     minBufferTime="PT1.5S"
     profiles="urn:mpeg:dash:profile:isoff-on-demand:2011">

  <Period id="1" start="PT0S">

    <AdaptationSet id="1" contentType="video" mimeType="video/mp4" segmentAlignment="true" startWithSAP="1">
      <SegmentTemplate initialization="$RepresentationID$/init.mp4"
                        media="$RepresentationID$/$Number$.m4s"
                        timescale="90000"
                        duration="270000"
                        startNumber="1"/>
      <Representation id="v1" bandwidth="5000000" codecs="avc1.640028" width="1920" height="1080" frameRate="30"/>
      <Representation id="v2" bandwidth="2800000" codecs="avc1.4d401f" width="1280" height="720"  frameRate="30"/>
      <Representation id="v3" bandwidth="1400000" codecs="avc1.4d401e" width="854"  height="480"  frameRate="30"/>
      <Representation id="v4" bandwidth="600000"  codecs="avc1.42c01e" width="640"  height="360"  frameRate="30"/>
    </AdaptationSet>

    <AdaptationSet id="2" contentType="audio" mimeType="audio/mp4" lang="en" segmentAlignment="true">
      <SegmentTemplate initialization="$RepresentationID$/init.mp4"
                        media="$RepresentationID$/$Number$.m4s"
                        timescale="44100"
                        duration="132300"
                        startNumber="1"/>
      <Representation id="a1" bandwidth="128000" codecs="mp4a.40.2"/>
    </AdaptationSet>

  </Period>
</MPD>
